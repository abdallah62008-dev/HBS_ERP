# -----------------------------------------------------------------------------
# Hnawbas Operations System — Staging environment template
#
# Copy this file to .env on the staging host:
#     cp .env.staging.example .env
#     php artisan key:generate
#
# Then fill in every <REPLACE_ME> with a real value. NEVER commit the
# resulting .env. NEVER copy production data or production credentials
# into staging unless explicitly approved.
# -----------------------------------------------------------------------------

APP_NAME="Hnawbas Operations"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Africa/Cairo
APP_URL=https://staging.hnawbas.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# File-based maintenance flag is fine for a single-host staging box.
APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# Keep info+ in staging so post-deploy smoke tests are diagnosable, but no debug.
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database — fresh staging schema, NOT cloned from production.
# Use a dedicated DB user with privileges scoped to the staging schema only.
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hbs_erp_staging
DB_USERNAME=hbs_staging
DB_PASSWORD=<REPLACE_ME_STRONG_PASSWORD>

# -----------------------------------------------------------------------------
# Sessions / Cache / Queue
# Database driver matches local development. If/when scale grows, switch
# session+cache to Redis without code changes.
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
CACHE_PREFIX=hbs_staging

QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log

# -----------------------------------------------------------------------------
# Filesystem — use the local disk; uploads land in storage/app/public,
# served via the public/storage symlink (php artisan storage:link).
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# Redis — only required if SESSION/CACHE/QUEUE are switched to redis.
# Default config keeps DB drivers, so these are placeholders.
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# -----------------------------------------------------------------------------
# Mail — staging should NOT silently send to real customers.
# Recommended: smtp pointed at a transactional-email sandbox (Mailtrap),
# or `log` driver to suppress sending entirely.
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="staging@hnawbas.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# AWS / S3 — left blank because the system uses local filesystem disk.
# Only fill if FILESYSTEM_DISK is later switched to s3.
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# Vite (build-time only). Mirrors APP_NAME.
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
